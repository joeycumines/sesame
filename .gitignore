# go ignores

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
# Test binary, built with `go test -c`
*.test
# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# other ignores

# optional build config
/config.mak

/.idea
/.vscode
/scratch
/DIRECTIVE.txt
/.claude/*.local.*
/.github/copilot-instructions.md
/.claude/agents
/.github/agents
/.claude/skills
*.log
